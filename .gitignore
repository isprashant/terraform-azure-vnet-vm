# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfplan files
*.tfplan

# Ignore CLI configuration files
.terraformrc
terraform.rc

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store   